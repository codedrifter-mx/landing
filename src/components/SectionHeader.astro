---
interface Props {
  label: string;
  id?: string;
}
const { label, id } = Astro.props;
---

<h2 class="section-header" id={id}>// {label}</h2>

<style>
  .section-header {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin: 0 0 1.5rem 0;
    font-weight: 600;
  }
</style>
